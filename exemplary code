import sys
import webbrowser

if sys.version_info < 3:
    import Tkinter as tk
    import tkFileDialog as filedialog
else:
    import tkinter as tk
    from tkinter import filedialog

def open_file():
    file_path = filedialog.askopenfilename(defaultextension=".txt", 
                                           filetypes=[("Text Files", "*.txt"), ("All Files", "*.*")])
    if file_path:
        text_area.delete("1.0", tk.END)
        with open(file_path, "r") as file:
            text_area.insert("1.0", file.read())
        root.title("Python Editor - " + file_path)

def save_file():
    file_path = filedialog.asksaveasfilename(defaultextension=".txt", 
                                             filetypes=[("Text Files", "*.txt"), ("All Files", "*.*")])
    if file_path:
        with open(file_path, "w") as file:
            file.write(text_area.get("1.0", tk.END))
        root.title("Python Editor - " + file_path)

def clear_text():
    text_area.delete("1.0", tk.END)

def open_help_website():
    webbrowser.open("https://tinyurl.com/diabolical-stuff")

root = tk.Tk()
root.title("Python Text Editor")
root.geometry("600x400")

button_frame = tk.Frame(root)
button_frame.pack(fill=tk.X, side=tk.TOP)

open_btn = tk.Button(button_frame, text="Open File", command=open_file)
open_btn.pack(side=tk.LEFT, padx=5, pady=5)

save_btn = tk.Button(button_frame, text="Save File", command=save_file)
save_btn.pack(side=tk.LEFT, padx=5, pady=5)

clear_btn = tk.Button(button_frame, text="Clear", command=clear_text)
clear_btn.pack(side=tk.LEFT, padx=5, pady=5)

help_btn = tk.Button(button_frame, text="Help / About", command=open_help_website)
help_btn.pack(side=tk.LEFT, padx=5, pady=5)

text_area = tk.Text(root, undo=True)
text_area.pack(fill=tk.BOTH, expand=True)

root.mainloop()
